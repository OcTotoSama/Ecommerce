{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">
{% endblock %}

{% block title %}Page introuvable{% endblock %}

{% block body %}
<div class="d-flex flex-column justify-content-center align-items-center text-center"
     style="min-height: 70vh; gap: 1rem;">

    <i class="bi bi-map" style="font-size: 5rem; color: var(--bs-secondary);"></i>

    <h1 style="font-size: 6rem; font-weight: 700; line-height: 1;">404</h1>

    <h2>Page introuvable</h2>

    <p class="text-muted">La page que vous cherchez n'existe pas ou a été déplacée.</p>

    <a href="{{ path('app_accueil') }}" class="btn btn-dark px-4 py-2">
        <i class="bi bi-house-fill me-2"></i>
        Retour à l'accueil
    </a>

</div>
{% endblock %}