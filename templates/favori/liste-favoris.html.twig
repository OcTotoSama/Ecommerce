{% extends 'base.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="css/css-card.css">
	<link rel="stylesheet" href="css/base.css">
	<link rel="stylesheet" href="css/favoris.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}

{% block body_attributes %}
	data-page="favoris"
{% endblock %}

{% block title %}
	{{parent()}}Mes favoris
{% endblock %}

{% block body %}


	{% if app.user.produits|length == 0 %}


		<div class="empty-favoris-container">
			<h1 class="favoris-title empty">Aucun favori</h1>

			<p class="empty-text">
				Vous n’avez pas encore ajouté de produit à vos favoris.
			</p>
		</div>


	{% else %}
		<h1 id="favoris-title" class="favoris-title">
			Mes favoris
		</h1>
		<div class="wrap">
			{% for produit in app.user.produits %}
				{% if produit in app.user.produits %}

					<div class="card_anime" data-id="{{ produit.id }}">

						<a href="javascript:void(0);" data-auth="true" class="favori-toggle" data-id="{{ produit.id }}" data-url="{{ path('app_favori', {'id': produit.id}) }}">

							{% if not is_granted('IS_AUTHENTICATED_FULLY') %}
								<i class="bi bi-heart favori"></i>
							{% else %}
								{% if produit in app.user.produits %}
									<i class="bi bi-heart-fill favori"></i>
								{% else %}
									<i class="bi bi-heart favori"></i>
								{% endif %}
							{% endif %}
						</a>


						{% set image = 'images/img_produit/'~ produit.image %}
						<div class="div_card_img">
							<img class="card-img-top" src="{{asset(image)}}" alt="Image de {{produit.designation}} ">
						</div>
						<div class="card_content">
							<p class="name">{{produit.name}}</p>
							<p class="explain">{{produit.designation}}</p>
							<p class="price">{{ produit.prix|number_format(2, '.', '') }}
								€</p>
						</div>
						<a href="{{ path('app_panier', {'id': produit.id}) }}" class="ajout-panier ajout_panier" data-id="{{ produit.id }}" data-url="{{ path('app_panier', {'id': produit.id}) }}" data-auth="{{ is_granted('IS_AUTHENTICATED_FULLY') ? 'true' : 'false' }}">
							<i class="bi bi-bag"></i>
							Add to Cart
						</a>
					</div>
				{% endif %}
			{% endfor %}
		</div>

	{% endif %}
{% endblock %}
