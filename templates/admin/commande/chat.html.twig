{% extends 'base.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

	<link rel="stylesheet" href="{{ asset('css/base.css') }}">
	<link rel="stylesheet" href="{{ asset('css/admin-chat.css') }}">
{% endblock %}

{% block title %}
	Commande #{{ commande.id }}
	— Tchat
{% endblock %}

{% block body %}

	<div class="admin-chat-page">

		<div class="admin-chat-header">

			<a href="{{ path('app_admin_commandes') }}" class="back-btn">
				<i class="bi bi-arrow-left"></i>
				Retour aux commandes
			</a>

			<h1 class="admin-chat-title">
				Tchat commande
				<span>#{{ commande.id }}</span>
			</h1>

			<div class="client-info">
				<div class="client-name">
					{{ commande.user.name }}
					{{ commande.user.surname }}
				</div>

				<div class="client-email">
					{{ commande.user.email }}
				</div>
			</div>

		</div>

		<div
			class="admin-chat-layout">

			{# ======================
								   CHAT
								====================== #}

			<div class="chat-card">

				<div class="chat-card-header">
					<h2>Conversation</h2>
				</div>

				<div class="chat-box" id="chat-box">

					{% for message in commande.messages %}

						<div class="chat-row {{ message.admin ? 'admin-row' : 'client-row' }}">

							<div class="chat-message {{ message.admin ? 'admin-message' : 'client-message' }}">

								<div class="chat-author">
									{{ message.admin ? 'Vous (admin)' : commande.user.name }}
								</div>

								<div class="chat-content">
									{{ message.contenu }}
								</div>

								<div class="chat-date">
									{{ message.dateEnvoi|date('d/m H:i') }}
								</div>

							</div>

						</div>

					{% else %}

						<div class="empty-chat">
							Aucun message.
						</div>

					{% endfor %}

				</div>

				<form method="post" id="chat-form" class="chat-form">

					<input type="text" name="contenu" class="chat-input" id="chat-input" placeholder="Écrire un message..." autocomplete="off" required>

					<button type="submit" class="send-btn">
						<i class="bi bi-send-fill"></i>
						Envoyer
					</button>

				</form>

			</div>

			{# ======================
								   RESUME COMMANDE
								====================== #}

			<div class="order-card">

				<div class="order-card-header">
					<h2>Résumé commande</h2>
				</div>

				<div class="order-info">

					<div class="order-info-item">
						<span class="label">Commande :</span>
						<span class="value">#{{ commande.id }}</span>
					</div>

					<div class="order-info-item">
						<span class="label">Client :</span>
						<span class="value">
							{{ commande.user.name }}
							{{ commande.user.surname }}
						</span>
					</div>

				</div>

				<div class="order-table-wrapper">

					<table class="order-table">

						<thead>
							<tr>
								<th>Produit</th>
								<th>Qté</th>
								<th>Total</th>
							</tr>
						</thead>

						<tbody>

							{% for ligne in commande.ligneCommandes %}

								<tr>
									<td>{{ ligne.produit.designation }}</td>

									<td>{{ ligne.quantite }}</td>

									<td>
										{{ (ligne.prixUnitaire * ligne.quantite)|number_format(2, '.', '') }}
										€
									</td>
								</tr>

							{% endfor %}

						</tbody>

					</table>

				</div>

				<div class="order-total">
					<span>Total TTC</span>

					<strong>
						{{ (commande.total * 1.2)|number_format(2, '.', '') }}
						€
					</strong>
				</div>

			</div>

		</div>

	</div>


{% endblock %}

{% block javascripts %}
	{{ parent() }}

	<script src="{{ asset('JS/chat-commande.js') }}"></script>
{% endblock %}
