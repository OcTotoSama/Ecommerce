{% extends 'base.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

	<link rel="stylesheet" href="{{ asset('css/base.css') }}">
	<link rel="stylesheet" href="{{ asset('css/commandes.css') }}">
{% endblock %}

{% block title %}
	Commandes
{% endblock %}

{% block body %}

	<div class="commandes-page">

		<div class="commandes-header">
			<h1 class="commandes-title">
				Gestion des commandes
			</h1>
		</div>

		{# =========================
			   COMMANDES NON LUES
			========================= #}

		{% if commandes_nonlues is not empty %}

			<div class="section-title unread-title">
				<i class="bi bi-bell-fill"></i>
				Commandes avec messages non lus
			</div>

			<div class="commandes-container mb-5">

				<div class="table-responsive">

					{{ _self.tableau(commandes_nonlues) }}

				</div>

			</div>

		{% endif %}

		{# =========================
			   TOUTES LES COMMANDES
			========================= #}

		<div class="section-title">
			<i class="bi bi-receipt"></i>
			Toutes les commandes
		</div>

		<div class="commandes-container">

			<div class="table-responsive">

				{{ _self.tableau(commandes) }}

			</div>

		</div>

	</div>

{% endblock %}


{% macro tableau(liste) %}

	{% set badges = {
    'en_preparation':     'warning',
    'en_cours_livraison': 'info',
    'livre':              'success'
} %}

	<table class="table commandes-table align-middle">

		<thead>
			<tr>
				<th>N°</th>
				<th>Client</th>
				<th>Date</th>
				<th>Total TTC</th>
				<th>État</th>
				<th>Msgs</th>
				<th>Actions</th>
			</tr>
		</thead>

		<tbody>

			{% for commande in liste %}

				<tr>

					<td>
						<span class="order-id">
							#{{ commande.id }}
						</span>
					</td>

					<td>

						<div class="client-block">

							<span class="client-name">
								{{ commande.user.name }}
								{{ commande.user.surname }}
							</span>

							<span class="user-email">
								{{ commande.user.email }}
							</span>

						</div>

					</td>

					<td class="date-cell">
						{{ commande.dateCommande|date('d/m/Y H:i') }}
					</td>

					<td>
						<span class="price-badge">
							{{ (commande.total * 1.2)|number_format(2, '.', '') }}
							€
						</span>
					</td>

					<td>
						<span class="badge state-badge bg-{{ badges[commande.etat] ?? 'secondary' }}">
							{{ commande.etat|replace({
                        'en_preparation':'En préparation',
                        'en_cours_livraison':'En cours de livraison',
                        'livre':'Livré'
                    }) }}
						</span>
					</td>

					<td>

						{% set nonLus = commande.nbNonLus %}

						{% if nonLus > 0 %}

							<span class="message-badge">
								{{ nonLus }}
							</span>

						{% else %}

							<span class="no-message">
								—
							</span>

						{% endif %}

					</td>

					<td>

						<div class="actions-group">

							<a href="{{ path('app_admin_commande_chat', {'id': commande.id}) }}" class="chat-btn">

								<i class="bi bi-chat-dots-fill"></i>
								Tchat

							</a>

							<a href="{{ path('app_admin_commande_etat', {'id': commande.id}) }}" class="edit-order-btn">

								<i class="bi bi-pencil-square"></i>
								État

							</a>

						</div>

					</td>

				</tr>

			{% endfor %}

		</tbody>

	</table>

{% endmacro %}
