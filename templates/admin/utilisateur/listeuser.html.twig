{% extends 'base.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="{{ asset('css/base.css') }}">
	<link rel="stylesheet" href="{{ asset('css/listeUtilisateur.css') }}">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}

{% block title %}
	{{ parent() }}Liste des utilisateurs
{% endblock %}

{% block body %}

	<div class="user-header">
		<h1 class="user-title">Liste des utilisateurs</h1>
	</div>

	<div class="page-wrapper">
		<div class="table-container">

			{{ form_start(form, {'attr': {'id': 'form-utilisateurs'}}) }}

			<div class="search-container">
				<i class="bi bi-search search-icon"></i>
				<input type="text" id="userSearch" class="user-search-input" placeholder="Rechercher un utilisateur...">
			</div>

			<div class="table-responsive">

				<table class="table custom-table align-middle">

					<thead class="custom-thead">
						<tr>
							<th>Nom</th>
							<th>Prénom</th>
							<th>Email</th>
							<th>Inscription</th>
							<th>Rôle</th>
							<th class="text-center">Modifier</th>
							<th class="text-center">Désactiver</th>
						</tr>
					</thead>

					<tbody id="table-actifs">

						{% for element in returns | filter(e => e.isActive)
                | sort((a, b) => b.DateInscription <=> a.DateInscription) %}

							<tr class="user-row">

								<td class="user-info-cell searchable">
									{{ element.name|length > 10 ? element.name|slice(0, 10) ~ '...' : element.name }}
								</td>

								<td class="user-info-cell searchable">
									{{ element.surname|length > 10 ? element.surname|slice(0, 10) ~ '...' : element.surname }}
								</td>

								<td class="email-cell searchable">
									{{ element.email }}
								</td>

								<td>
									<span class="date-badge">
										{{ element.DateInscription|date("d-m-Y") }}
									</span>
								</td>


								<td>
									{% if 'ROLE_PROPRIETAIRE' in element.roles %}
										<span class="role-badge role-admin">
											<i class="bi bi-stars"></i>
											Propriétaire
										</span>

									{% elseif is_granted('ROLE_PROPRIETAIRE') %}
										<button type="button" class="role-badge {{ 'ROLE_ADMIN' in element.roles ? 'role-admin' : 'role-user' }} border-0" title="Cliquer pour changer le rôle" data-url="{{ path('app_changer_role', {'id': element.id}) }}" onclick="changerRole(this)">
											{% if 'ROLE_ADMIN' in element.roles %}
												<i class="bi bi-shield-lock-fill"></i>
												Admin
											{% else %}
												<i class="bi bi-person-fill"></i>
												User
											{% endif %}
										</button>

									{% else %}
										<span class="role-badge {{ 'ROLE_ADMIN' in element.roles ? 'role-admin' : 'role-user' }}">
											{% if 'ROLE_ADMIN' in element.roles %}
												<i class="bi bi-shield-lock-fill"></i>
												Admin
											{% else %}
												<i class="bi bi-person-fill"></i>
												User
											{% endif %}
										</span>
									{% endif %}
								</td>


								<td class="text-center action-cell">

									{% if 'ROLE_PROPRIETAIRE' in element.roles  %}
										<i class="bi bi-lock-fill text-muted"></i>
									{% else %}
										{% if 'ROLE_ADMIN' in element.roles and not is_granted('ROLE_PROPRIETAIRE') %}
											<i class="bi bi-lock-fill text-muted"></i>
										{% else %}
											<a href="{{ path('app_modifier_utilisateur', {'id': element.id}) }}" class="action-icon">
												<i class="bi bi-pen-fill"></i>
											</a>
										{% endif %}

									{% endif %}

								</td>

								<td class="text-center action-cell">
									{% if 'ROLE_PROPRIETAIRE' in element.roles  %}
										<i class="bi bi-lock-fill text-muted"></i>
									{% else %}
										{% if 'ROLE_ADMIN' in element.roles and not is_granted('ROLE_PROPRIETAIRE') %}
											<i class="bi bi-lock-fill text-muted"></i>
										{% else %}
											<a href="{{ path('app_desactiver_utilisateur', {'id': element.id}) }}" class="action-icon danger">
												<i class="bi bi-person-dash-fill"></i>
											</a>
										{% endif %}
									{% endif %}
								</td>

							</tr>

						{% endfor %}

					</tbody>

				</table>

			</div>

			{{ form_end(form, {'render_rest': false}) }}

		</div>
	</div>

	{# ================= INACTIFS ================= #}

	{% if inactifs is not empty %}

		<div class="page-wrapper mt-5">
			<div class="table-container">

				<h2 class="section-title-danger">Comptes désactivés</h2>

				<div class="table-responsive">

					<table class="table custom-table">

						<thead class="custom-thead">
							<tr>
								<th>Nom</th>
								<th>Prénom</th>
								<th>Email</th>
								<th>Date</th>
								<th class="text-center">Réactiver</th>
							</tr>
						</thead>

						<tbody id="table-inactifs">

							{% for element in inactifs %}
								<tr class="inactive-row user-row">
									<td class="searchable">{{ element.name }}</td>
									<td class="searchable">{{ element.surname }}</td>
									<td class="searchable">{{ element.email }}</td>
									<td>{{ element.DateInscription|date('d/m/Y') }}</td>
									<td class="text-center">
										<a href="{{ path('app_reactiver_utilisateur', {'id': element.id}) }}" class="action-icon success">
											<i class="bi bi-arrow-counterclockwise"></i>
										</a>
									</td>
								</tr>
							{% endfor %}

						</tbody>

					</table>

				</div>

			</div>
		</div>

	{% endif %}

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('JS/changerRole.js') }}"></script>
{% endblock %}
