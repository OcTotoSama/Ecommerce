{% extends 'base.html.twig' %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

	<link rel="stylesheet" href="{{ asset('css/base.css') }}">
	<link rel="stylesheet" href="{{ asset('css/list-evaluations.css') }}">
{% endblock %}

{% block title %}
	{{ parent() }}Avis clients
{% endblock %}

{% block body %}

	<div class="user-header">
		<h1 class="user-title">Avis clients</h1>
	</div>

	<div class="reviews-counter-wrapper">
		<div class="reviews-counter">
			<span class="reviews-label">Nombre d’avis</span>
			<span class="reviews-value" id="stat-nb-evaluations">{{ evaluations|length }}</span>
		</div>
	</div>

	<div class="page-wrapper">
		<div class="table-container">

			<div class="table-responsive">
				<table class="table custom-table align-middle">

					<thead class="custom-thead">
						<tr>
							<th>Produit</th>
							<th>Image</th>
							<th>Client</th>
							<th class="text-center">Note</th>
							<th class="text-center">Supprimer</th>
						</tr>
					</thead>

					<tbody>
						{% for evaluation in evaluations %}
							<tr>

								<td>{{ evaluation.produit.name }}</td>

								<td>
									<img src="{{ asset('images/img_produit/' ~ evaluation.produit.image) }}" alt="{{ evaluation.produit.name }}" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
								</td>

								<td>{{ evaluation.user.email }}</td>

								<td class="text-center">
									{% for i in 1..5 %}
										{% if i <= evaluation.note %}
											<i class="bi bi-star-fill text-warning"></i>
										{% else %}
											<i class="bi bi-star text-muted"></i>
										{% endif %}
									{% endfor %}
									<span class="ms-1">({{ evaluation.note }}/5)</span>
								</td>
								<td class="text-center action-cell">
									<button type="button" class="action-icon danger" data-url="{{ path('app_admin_evaluation_supprimer', {'id': evaluation.id}) }}" onclick="supprimerEvaluation(this)">
										<i class="bi bi-trash-fill"></i>
									</button>
								</td>

							</tr>
						{% else %}
							<tr>
								<td colspan="4" class="text-center text-muted py-4">Aucun avis pour le moment.</td>
							</tr>
						{% endfor %}
					</tbody>

				</table>
			</div>

		</div>
	</div>

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('JS/supprimerEvaluation.js') }}"></script>
{% endblock %}
