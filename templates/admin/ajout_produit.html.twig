{% extends 'base.html.twig' %}

{% block title %}
    Ajout Produit
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-lg-6 col-md-8 col-sm-10">

        <div class="card shadow-lg border-0" style="background:#fff;">
            <div class="card-header text-center" style="background:#000; color:#fff;">
                <h2 class="my-2 fw-bold">Ajout Produit</h2>
            </div>

            <div class="card-body px-5 py-4">

                {{ form_start(form) }}

                    <div class="mb-3">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.designation) }}
                        {{ form_widget(form.designation, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.image) }}
                        {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.prix) }}
                        {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="text-center mt-4">
                        <button class="btn btn-dark px-4 py-2 rounded-1 fw-bold">
                            Ajouter
                        </button>
                    </div>

                {{ form_end(form) }}

            </div>
        </div>

    </div>
</div>
{% endblock %}