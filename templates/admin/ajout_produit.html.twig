
{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">
    <link rel="stylesheet" href="{{ asset('css/ajoutProduit.css') }}">
{% endblock %}

{% block title %}
    Ajout Produit
{% endblock %}

{% block body %}

<div class="product-page">

    <h1 class="product-form-title">
        Ajouter un produit
    </h1>

    <div class="product-form-container">

        {{ form_start(form) }}

            <div class="form-group-custom">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-group-custom">
                {{ form_label(form.designation) }}
                {{ form_widget(form.designation, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-group-custom">
                {{ form_label(form.image) }}
                {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-group-custom">
                {{ form_label(form.prix) }}
                {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="submit-container">

                <button class="submit-btn" type="submit">
                    Ajouter le produit
                </button>

            </div>

        {{ form_end(form) }}

        <div class="back-button-container">

            <a class="back-btn" href="{{ path('app_liste_produits') }}">
                Voir la liste des produits
            </a>

        </div>

    </div>

</div>

{% endblock %}