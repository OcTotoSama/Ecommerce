{% extends 'base.html.twig' %}
{% block stylesheets %}
	<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
	<link rel="stylesheet" href="css/base.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
	<link rel="stylesheet" href="css/register.css">
{% endblock %}
{% block title %}
	Inscription
{% endblock %}

{% block body %}
	<div class="back_login">
		<div class="container d-flex justify-content-center align-items-center " style="min-height: 80vh;">

			<div class="col-lg-5 col-md-7 col-sm-10 mt-5">

				<div class="card shadow-lg border-0" style="background:#fff;">

					<div class="card-header text-center" style="background:#000; color:#fff;">
						<h2 class="my-2 fw-bold">Inscription</h2>
					</div>

					<div class="card-body px-5 py-4">

						{{ form_errors(registrationForm) }}

						{{ form_start(registrationForm) }}


						<div class="mb-3">
							{{ form_label(registrationForm.name) }}
							{{ form_widget(registrationForm.name, {'attr': {'class': 'form-control'}}) }}
						</div>

						<div class="mb-3">
							{{ form_label(registrationForm.surname) }}
							{{ form_widget(registrationForm.surname, {'attr': {'class': 'form-control'}}) }}
						</div>

						<div class="mb-3">
							{{ form_label(registrationForm.email) }}
							{{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
						</div>

						<div class="mb-3">
							{{ form_label(registrationForm.plainPassword, 'Password') }}
							{{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
						</div>

						<div class="mb-3 form-check">
							{{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
							{{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'form-check-label'}}) }}
						</div>

						<div class="text-center mt-4">
							<button class="btn btn-dark px-4 py-2 rounded-1 fw-bold" type="submit">
								S’inscrire
							</button>
						</div>

						{{ form_end(registrationForm) }}
						<div class="text-center">
							<button class="btn mt-3 rounded-1" >
								<a class="nav-link" href="{{path('app_login')}}">vous avez déjà un compte ? connectez vous ici</a>
							</button>
						</div>

					</div>

				</div>

			</div>
		</div>
	</div>
{% endblock %}
