<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}NovaSprite
			{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('images/img_icon/icon5.png') }}">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

		{% block stylesheets %}
			<link rel="stylesheet" href="https://bootswatch.com/5/sandstone/bootstrap.min.css">
			<link rel="stylesheet" href="{{ asset('css/base.css') }}">
			<link rel="stylesheet" href="{{ asset('css/css-card.css') }}">
			<link rel="stylesheet" href="{{ asset('css/carousel-produit.css') }}">
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
		{% endblock %}


	</head>
	<body {% block body_attributes %} {% endblock %}>
		<nav class="navbar navbar-expand-lg custom-navbar" data-bs-theme="dark">
			<div class="container-fluid">

				<a class="navbar-brand center_navbar_icon" href="{{path('app_accueil')}}">
					<img class="icon_navbar" src="{{ asset('images/img_icon/icon5.png') }}" alt="Icon site">
					NovaSprite
				</a>

				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="collapse navbar-collapse" id="navbarColor01">

					<ul class="navbar-nav me-auto align-items-lg-center">

						{% if not is_granted('IS_AUTHENTICATED_FULLY') %}

							<li class="nav-item">
								<a class="nav-link nav-pill" href="{{path('app_liste_tous_produit')}}">
									Tous les produits
								</a>
							</li>

							<li class="nav-item dropdown nav-dropdown">
								<a class="nav-link dropdown-toggle nav-pill" href="#" role="button" data-bs-toggle="dropdown">
									Login
								</a>

								<ul class="dropdown-menu custom-dropdown">
									<li>
										<a class="dropdown-item" href="{{path('app_login')}}">Se connecter</a>
									</li>
									<li>
										<a class="dropdown-item" href="{{path('app_register')}}">S'inscrire</a>
									</li>
								</ul>
							</li>

						{% else %}

							{% if not is_granted('ROLE_ADMIN') %}

								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path('app_liste_tous_produit')}}">
										Tous les produits
									</a>
								</li>

								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path("app_liste_favoris")}}">
										<i class="bi bi-heart-fill"></i>
										Favoris
									</a>
								</li>

								

								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path("app_liste_panier")}}">
										<i class="bi bi-basket"></i>
										Panier
										<span id="cart-count" class="cart-badge">
											{{ app.user.panier ? app.user.panier.ajouters|reduce((carry, a) => carry + a.quantite, 0) : 0 }}
										</span>
									</a>
								</li>


								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path("app_mes_commandes")}}">
										Commandes
									</a>
								</li>

							{% else %}

								<span class="admin-badge">Administration</span>

								<li class="nav-item dropdown nav-dropdown">
									<a class="nav-link dropdown-toggle nav-pill" href="#" data-bs-toggle="dropdown">
										Produit
									</a>

									<ul class="dropdown-menu custom-dropdown">
										<li>
											<a class="dropdown-item" href="{{path("app_liste_produits")}}">Liste Produit</a>
										</li>
										<li>
											<a class="dropdown-item" href="{{path("app_admin_ajout")}}">Ajout Produit</a>
										</li>
									</ul>
								</li>

								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path("app_liste_utilisateur")}}">
										Utilisateurs
									</a>
								</li>

								<li class="nav-item">
									<a class="nav-link nav-pill" href="{{path("app_admin_commandes")}}">
										Commandes
									</a>
								</li>

							{% endif %}

							<li class="nav-item">
								<a class="nav-link profile-pill" href="{{path("app_profil")}}">
									<i class="bi bi-person-circle"></i>
									Profil
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link nav-pill danger-pill" href="{{path("app_logout")}}">
									Déconnexion
								</a>
							</li>

						{% endif %}

					</ul>

				</div>
			</div>
		</nav>

		<main>


			{% block body %}{% endblock %}

		</main>

		<footer class="site-footer">

			<div class="footer-content">

				<div class="footer-block">
					<span class="footer-title">NovaSprite</span>
					<p class="footer-text">
						Boutique en ligne dédiée à la découverte de produits uniques et stylés.
					</p>
				</div>

				<div class="footer-block">
					<span class="footer-title">Projet</span>
					<p class="footer-text">
						Développé par © DOMINOIS Thomas
					</p>
					<p class="footer-text">
						Année de création : 2026
					</p>
				</div>

				<div class="footer-block">
					<span class="footer-title">Navigation</span>
					<a href="{{ path('app_accueil') }}" class="footer-link">Accueil</a>
					<a href="{{ path('app_liste_tous_produit') }}" class="footer-link">Produits</a>
				</div>

			</div>

			<div class="footer-bottom">
				<p>©
					{{ "now"|date("Y") }}
					NovaSprite — Tous droits réservés</p>
			</div>

		</footer>

		{% block javascripts %}
			{# script du carousel (déféré) #}
			<script src="{{ asset('JS/carousel-responsive.js') }}" defer></script>

			{# variable côté client (utile pour global.js) #}
			<script>
				const ACCUEIL_URL = "{{ path('app_accueil') }}";
			</script>

			{# Bootstrap JS : une seule inclusion, bundle (Popper inclus) #}
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous" defer></script>

			{# global.js doit s'exécuter après Bootstrap : utiliser defer pour préserver l'ordre #}
			<script src="{{ asset('JS/global.js') }}" defer></script>
		{% endblock %}


	</body>
</html>
